{
  "name": "wappiz",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "better-auth": "1.5.2",
      "dotenv": "^17.2.2",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "typescript": "^5",
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:mail": "turbo -F @wappiz/resend dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @wappiz/db db:push",
    "db:studio": "turbo -F @wappiz/db db:studio",
    "db:generate": "turbo -F @wappiz/db db:generate",
    "db:migrate": "turbo -F @wappiz/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@posthog/react": "^1.9.0",
    "@wappiz/env": "workspace:*",
    "dotenv": "catalog:",
    "posthog-node": "^5.29.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@wappiz/config": "workspace:*",
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "ultracite": "7.6.1"
  },
  "packageManager": "bun@1.3.3"
}
